# Server Configuration
PORT=3001
NODE_ENV=development
CORS_ORIGIN=http://localhost:3000

# Supabase Configuration
SUPABASE_URL=your_supabase_project_url
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_KEY=your_supabase_service_role_key

# Paystack Configuration
PAYSTACK_SECRET_KEY=your_paystack_secret_key
PAYSTACK_PUBLIC_KEY=your_paystack_public_key
PAYSTACK_CALLBACK_URL=http://localhost:3000/wallet

# VTPass Configuration (for Airtime & Data purchases)
VTPASS_EMAIL=your_vtpass_email
VTPASS_API_KEY=your_vtpass_api_key
VTPASS_PUBLIC_KEY=your_vtpass_public_key

# Webhook URL - Update this to your deployed backend URL
PAYSTACK_WEBHOOK_URL=https://your-domain.com/api/payment/webhook